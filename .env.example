OPENAI_API_KEY=sk-your-key-here
HEADLESS=true

# Twilio WhatsApp Sandbox (free) - get from twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Gemini API key for natural language intent parsing
GEMINI_API_KEY=your_gemini_key_here

# Bot port (Flask webhook server)
BOT_PORT=5000

# Phone numbers are in config.yaml under whatsapp_targets (per-category)
